# Ruflo v3.5 — Railway MCP Server (Streamable HTTP)
#
# Deploys the MCP server with Streamable HTTP transport for remote access.
# Railway sets PORT automatically; the server binds to 0.0.0.0:$PORT.
#
# Build:
#   docker build -t ruflo:railway -f v3/@claude-flow/cli/docker/Dockerfile.railway .
#
# Run locally:
#   docker run --rm -p 3000:3000 ruflo:railway
#
# Connect from Claude Code:
#   claude mcp add --transport http ruflo https://your-app.up.railway.app/mcp

# ── Stage 1: Install & Build ──────────────────────────────────
FROM node:22-alpine AS build

RUN apk add --no-cache git

WORKDIR /install

# Install ruflo globally with --omit=optional to keep the image small.
RUN npm install -g ruflo@latest \
      --omit=optional \
      --ignore-scripts \
      --no-audit \
      --no-fund \
    && npm cache clean --force

# Install the Streamable HTTP dependencies into the ruflo package tree.
# These are needed at runtime for the HTTP transport.
RUN GLOBAL_PREFIX=$(npm config get prefix) \
    && cd "${GLOBAL_PREFIX}/lib/node_modules/ruflo" \
    && npm install --save \
      @modelcontextprotocol/sdk@latest \
      express@^4.21.0 \
      zod@^3.23.0 \
      --no-audit --no-fund \
    && npm cache clean --force

# Prune heavy optional deps that aren't needed for the MCP HTTP server.
RUN GLOBAL_PREFIX=$(npm config get prefix) \
    && CLI_NM="${GLOBAL_PREFIX}/lib/node_modules/ruflo/node_modules" \
    && rm -rf \
      "${CLI_NM}/agentic-flow" \
      "${CLI_NM}/@opentelemetry" \
      "${CLI_NM}/onnxruntime-node" \
      "${CLI_NM}/onnxruntime-web" \
      "${CLI_NM}/onnx-proto" \
      "${CLI_NM}/@anthropic-ai" \
      "${CLI_NM}/@xenova" \
      "${CLI_NM}/agentdb" \
      "${CLI_NM}/@ruvector" \
      "${CLI_NM}/ruvector" \
      "${CLI_NM}/tiktoken" \
      "${CLI_NM}/@img" \
      "${CLI_NM}/better-sqlite3" \
      "${CLI_NM}/sharp" \
      "${CLI_NM}/@google" \
    && rm -rf \
      "${CLI_NM}/@claude-flow/embeddings" \
      "${CLI_NM}/@claude-flow/memory" \
      "${CLI_NM}/@claude-flow/codex" \
      "${CLI_NM}/@claude-flow/guidance" \
      "${CLI_NM}/@claude-flow/aidefence" \
      "${CLI_NM}/@claude-flow/plugin-gastown-bridge" \
      "${CLI_NM}/@claude-flow/neural" \
    && rm -rf \
      "${CLI_NM}/ruvector-onnx-embeddings-wasm" \
      "${CLI_NM}/ruvector-core-linux-x64-gnu" \
      "${CLI_NM}/@grpc" \
      "${CLI_NM}/gun"

# Stage the pruned global install
RUN GLOBAL_PREFIX=$(npm config get prefix) \
    && mkdir -p /staged/lib /staged/bin \
    && cp -a "${GLOBAL_PREFIX}/lib/node_modules" /staged/lib/ \
    && cp -a "${GLOBAL_PREFIX}/bin/ruflo" /staged/bin/ 2>/dev/null || true \
    && cp -a "${GLOBAL_PREFIX}/bin/claude-flow" /staged/bin/ 2>/dev/null || true

# ── Stage 2: Production ──────────────────────────────────────
FROM node:22-alpine AS production

RUN apk add --no-cache dumb-init git bash ca-certificates curl

# Non-root user
RUN addgroup -g 1001 -S ruflo \
    && adduser -S -D -H -u 1001 -h /home/ruflo -s /bin/bash -G ruflo ruflo \
    && mkdir -p /home/ruflo/.claude-flow /workspace \
    && chown -R ruflo:ruflo /home/ruflo /workspace

# Copy global node_modules and bin from build stage
COPY --from=build /staged/lib/node_modules /usr/local/lib/node_modules
COPY --from=build /staged/bin/ /usr/local/bin/

# Ensure bin symlinks
RUN ln -sf /usr/local/lib/node_modules/ruflo/bin/ruflo.js /usr/local/bin/ruflo 2>/dev/null || true \
    && chmod +x /usr/local/bin/ruflo 2>/dev/null || true

# Copy the standalone HTTP server entry point from the repo.
# These files are NOT in the published npm package yet, so we bundle them
# directly from the repo into a known location inside the image.
COPY v3/@claude-flow/cli/docker/start-http.js /app/start-http.js
COPY v3/@claude-flow/cli/docker/resolve-cli.js /app/resolve-cli.js
COPY v3/@claude-flow/cli/docker/app-package.json /app/package.json

ENV NODE_ENV=production \
    CLAUDE_FLOW_LOG_LEVEL=info \
    HOME=/home/ruflo \
    NODE_PATH=/usr/local/lib/node_modules/ruflo/node_modules:/usr/local/lib/node_modules

# Railway sets PORT automatically; default to 3000 for local testing
ENV PORT=3000

# Health check against the HTTP endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:${PORT}/health || exit 1

USER ruflo
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/dumb-init", "--"]

# Start the Streamable HTTP MCP server
CMD ["node", "/app/start-http.js"]
